{
  "manifest_version": 3,
  "name": "FlowBatch — Автоматизация Google Flow",
  "version": "0.3.0",
  "description": "Пакетная генерация видео и изображений в Google Flow (Nano Banana Pro, Veo 3.1) с авто-скачиванием в 4K",

  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "sidePanel"
  ],

  "host_permissions": [
    "https://labs.google/*",
    "https://flow.google/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/tools/flow/*",
        "https://flow.google/*"
      ],
      "js": ["lib/selectors.js", "content.js"],
      "css": [],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FlowBatch — открыть панель"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://labs.google/*", "https://flow.google/*"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
