{
  "manifest_version": 3,
  "name": "Flow Banana Automator",
  "version": "3.0.0",
  "description": "Batch generation + 4K upscale + auto-download for Google Flow",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "sidePanel",
    "debugger"
  ],
  "host_permissions": [
    "https://labs.google/fx/*",
    "https://aisandbox-pa.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/fx/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js", "api-bridge.js"],
      "matches": ["https://labs.google/fx/*"]
    }
  ],
  "action": {
    "default_title": "Flow Banana Automator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
